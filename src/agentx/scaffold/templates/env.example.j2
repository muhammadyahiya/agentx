# --- Provider selection (read by agentx) ---
AGENTX_PROVIDER={{ spec.provider }}
AGENTX_MODEL={{ model }}
AGENTX_TEMPERATURE=0.3

# --- Credentials for {{ provider_label }} ---
{% for v in provider_env %}
{{ v }}=
{% endfor %}
{% if not provider_env %}
# {{ provider_label }} is local — no API key required.
{% endif %}
