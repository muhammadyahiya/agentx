"""Graph state schema for {{ spec.slug }}.

The state is what flows between nodes in the LangGraph workflow. ``messages`` uses
the ``add_messages`` reducer so each node appends to the running conversation.
"""
from __future__ import annotations

from typing import Annotated, TypedDict

from langchain_core.messages import AnyMessage
from langgraph.graph.message import add_messages


class AgentState(TypedDict):
    """Shared state passed through the graph."""

    messages: Annotated[list[AnyMessage], add_messages]
{% if multi_agent %}
    # Supervisor routing: the name of the next worker to run, or "FINISH".
    next: str
{% endif %}
